<Window x:Class="Librya.AddEditBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Librya"
        mc:Ignorable="d"
        Title="AddEditBookWindow" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Название книги:" Margin="0,0,0,5" FontWeight="Bold"/>
        <TextBox x:Name="TxtTitle" Grid.Row="1" Margin="0,0,0,15" Height="30"/>

        <TextBlock Grid.Row="2" Text="Автор:" Margin="0,0,0,5" FontWeight="Bold"/>
        <TextBox x:Name="TxtAuthor" Grid.Row="3" Margin="0,0,0,15" Height="30"/>

        <TextBlock Grid.Row="4" Text="Жанр:" Margin="0,0,0,5" FontWeight="Bold"/>
        <ComboBox x:Name="TxtGenres" Grid.Row="5" Margin="0,0,0,15" Height="30"/>

        <TextBlock Grid.Row="6" Text="Год издания:" FontWeight="Bold" Height="16" VerticalAlignment="Top"/>
        <TextBox x:Name="TxtYear" Grid.Row="6" Margin="0,20,0,0" Height="30" Grid.RowSpan="2" VerticalAlignment="Top"/>

        <TextBlock Grid.Row="7" Text="Цена:" Margin="0,41,0,0" FontWeight="Bold" Height="45" VerticalAlignment="Top"/>
        <TextBox x:Name="TxtPrice" Grid.Row="7" Margin="0,61,0,0" Height="30" VerticalAlignment="Top"/>

        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="BtnSave" Content="Сохранить" Width="100" Height="30" 
                    Margin="0,0,10,0" Click="BtnSave_Click" Background="#4CAF50" Foreground="White"/>
            <Button x:Name="BtnCancel" Content="Отмена" Width="100" Height="30" 
                    Click="BtnCancel_Click" Background="#9E9E9E" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
